# 本地开发端口
PORT=3000

# 本地/非云托管调试：设为 1 且 NODE_ENV 非 production 时，允许用请求头 X-User-Id 作为用户（默认 "1"）。
# 微信云托管正式链路请勿设置，应依赖网关注入的 X-WX-OPENID。
# ALLOW_X_USER_ID_DEV=1

# 可选：本地调试时可填写；部署到 Vercel 时请在 Vercel Project Settings -> Environment Variables 中配置
DEEPSEEK_API_KEY=

# 可选：DeepSeek 兼容 OpenAI 接口地址
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
