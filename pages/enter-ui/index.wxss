.enter-ui {
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  box-sizing: border-box;
}

.page-bg-layer {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  pointer-events: none;
}

.page-bg-breathe-enter {
  animation: mainPageBgBreathe 3.2s ease-in-out infinite;
}

/* 视口顶端约 10% 处，纵向覆盖 120px */
.bubble-layer {
  position: absolute;
  left: 0;
  right: 0;
  top: 10%;
  height: 120px;
  z-index: 1;
  pointer-events: none;
  overflow: visible;
}

.foam-bubble {
  position: absolute;
  bottom: 0;
  border-radius: 50%;
  border: 2rpx solid rgba(90, 90, 90, 0.65);
  background: rgba(255, 255, 255, 0.32);
  animation-timing-function: ease-in-out;
  animation-iteration-count: infinite;
}

.foam-a {
  width: 22rpx;
  height: 22rpx;
  left: 6%;
  animation-name: foamPopEnter;
  animation-duration: 3.4s;
  animation-delay: 0s;
}

