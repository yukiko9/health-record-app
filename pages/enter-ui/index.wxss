@keyframes foamPopEnter {
  0% {
    opacity: 0;
    transform: translateY(8rpx) scale(0.32);
  }
  28% {
    opacity: 1;
    transform: translateY(-36rpx) scale(1.02);
  }
  100% {
    opacity: 0;
    transform: translateY(-88rpx) scale(0.16);
  }
}

@keyframes foamPopEnterAlt {
  0% {
    opacity: 0;
    transform: translateY(12rpx) scale(0.26);
  }
  32% {
    opacity: 0.95;
    transform: translateY(-40rpx) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateY(-96rpx) scale(0.14);
  }
}

.enter-ui-foreground {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 58rpx 24rpx 120rpx;
  box-sizing: border-box;
}

.enter-main {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
}

.goal-tip {
  font-size: 40rpx;
  color: #3d4a33;
  line-height: 50px;
  text-align: center;
  border-radius: 20rpx;
  padding: 14rpx 22rpx;
}

.goal {
  font-size: 54rpx;
  font-weight: 700;
  color: #2d2f3a;
}

.situation {
  color: #2f7f37;
}

.enter-ui .mood-nudge-wrap {
  margin-top: 30rpx;
  line-height: 1;
}

.enter-ui .mood-emoji.icon-emoji {
  font-size: 80px;
}

.enter-ui .score.label-strong {
  font-size: 200rpx;
  line-height: 1;
  letter-spacing: 2rpx;
  color: #1e2a18;
}

.username-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  width: 100%;
  max-width: 620rpx;
}

.username {
  font-size: 54rpx;
  text-align: center;
}

.sync-nickname-btn {
  font-size: 28rpx;
  font-weight: 700;
  padding: 12rpx 28rpx;
  text-align: center;
}

.float-tip {
  margin-top: 50rpx;
  font-size: 42rpx;
  color: rgba(0, 0, 0, 0.42);
  animation: floatTipBreathe 3.2s ease-in-out infinite, floatTipBump 2.15s ease-in-out infinite;
}

@keyframes floatTipBreathe {
  0%,
  100% {
    opacity: 0.18;
  }
  50% {
    opacity: 1;
  }
}

@keyframes floatTipBump {
  0%,
  100% {
    transform: translateY(0);
  }
  25% {
    transform: translateY(6rpx);
  }
  50% {
    transform: translateY(-12rpx);
  }
  75% {
    transform: translateY(4rpx);
  }
}

.readme-fab-col {
  position: fixed;
  right: 32rpx;
  bottom: 48rpx;
  z-index: 30;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.readme-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 900;
  color: #173812;
  background: linear-gradient(180deg, #61f751 0%, #41db37 100%);
  border: 3rpx solid #3cae44;
  box-shadow: 0 10rpx 18rpx rgba(38, 62, 35, 0.22);
}

.readme-fab-caption {
  font-size: 22rpx;
  font-weight: 700;
  color: #3d4a33;
}

.readme-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 28rpx;
  box-sizing: border-box;
}

.readme-page {
  position: relative;
  width: 100%;
  max-width: 620rpx;
  max-height: 72vh;
  padding: 48rpx 28rpx 28rpx;
  display: flex;
  flex-direction: column;
}

.readme-close {
  position: absolute;
  right: 12rpx;
  top: 8rpx;
  font-size: 48rpx;
  line-height: 1;
  color: #b32b2b;
  padding: 8rpx 20rpx;
}

.readme-scroll {
  flex: 1;
  max-height: 58vh;
  margin-top: 8rpx;
}

.readme-placeholder {
  font-size: 30rpx;
  line-height: 1.55;
  color: #2e3238;
}
