.enter-ui {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 32rpx 24rpx 120rpx;
  box-sizing: border-box;
}

.enter-main {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
}

.goal-tip {
  font-size: 40rpx;
  color: #3d4a33;
  background: rgba(255, 255, 255, 0.42);
  border-radius: 20rpx;
  padding: 14rpx 22rpx;
  box-shadow: 0 8rpx 16rpx rgba(38, 62, 35, 0.12);
  border: 2rpx solid rgba(105, 131, 95, 0.35);
}

.goal {
  font-size: 54rpx;
  font-weight: 700;
  color: #2d2f3a;
}

.situation {
  color: #2f7f37;
}

.mood-emoji {
  margin-top: 30rpx;
  font-size: 200rpx;
}

.enter-ui .score.label-strong {
  font-size: 300rpx;
  line-height: 1;
  letter-spacing: 2rpx;
  color: #ffffff;
  text-shadow: none;
}

.username-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  width: 100%;
  max-width: 620rpx;
}

.username {
  font-size: 54rpx;
  text-align: center;
}

.sync-nickname-btn {
  font-size: 28rpx;
  font-weight: 700;
  padding: 12rpx 28rpx;
  text-align: center;
}

.float-tip {
  margin-top: 50rpx;
  font-size: 42rpx;
  color: rgba(0, 0, 0, 0.4);
}

.readme-fab-col {
  position: fixed;
  right: 32rpx;
  bottom: 48rpx;
  z-index: 30;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.readme-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 900;
  color: #173812;
  background: linear-gradient(180deg, #61f751 0%, #41db37 100%);
  border: 3rpx solid #3cae44;
  box-shadow: 0 10rpx 18rpx rgba(38, 62, 35, 0.22);
}

.readme-fab-caption {
  font-size: 22rpx;
  font-weight: 700;
  color: #3d4a33;
}

.readme-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 28rpx;
  box-sizing: border-box;
}

.readme-page {
  position: relative;
  width: 100%;
  max-width: 620rpx;
  max-height: 72vh;
  padding: 48rpx 28rpx 28rpx;
  display: flex;
  flex-direction: column;
}

.readme-close {
  position: absolute;
  right: 12rpx;
  top: 8rpx;
  font-size: 48rpx;
  line-height: 1;
  color: #b32b2b;
  padding: 8rpx 20rpx;
}

.readme-scroll {
  flex: 1;
  max-height: 58vh;
  margin-top: 8rpx;
}

.readme-placeholder {
  font-size: 30rpx;
  line-height: 1.55;
  color: #2e3238;
}
