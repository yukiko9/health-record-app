.main-ui {
  position: relative;
  background: transparent;
  padding-bottom: 48rpx;
  overflow: hidden;
}

.page-bg-layer {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  pointer-events: none;
}

.page-bg-breathe {
  animation: mainPageBgBreathe 3.2s ease-in-out infinite;
}

.main-ui-foreground {
  position: relative;
  z-index: 1;
}

.header-panel {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.duration-panel {
  width: 130rpx;
  height: 140rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  backdrop-filter: blur(4rpx);
  box-shadow: 0 6rpx 14rpx rgba(38, 62, 35, 0.1);
  transition: background 0.45s ease, box-shadow 0.45s ease;
}

.duration-panel.goal-met-glow {
  background: linear-gradient(165deg, #fff8e1 0%, #ffe082 55%, #ffecb3 100%) !important;
  animation: goalMetPanelPulse 2.4s ease-in-out infinite;
  box-shadow: 0 6rpx 18rpx rgba(180, 140, 40, 0.35);
}

.duration-label {
  font-size: 24rpx;
  color: #5d6647;
}

.duration {
  font-size: 68rpx;
  color: #b32b2b;
  font-weight: 700;
}

.record-week-bar {
  flex: 1;
  display: flex;
  padding: 12rpx 8rpx 16rpx;
  justify-content: space-between;
  align-items: flex-end;
  gap: 6rpx;
  background: rgba(255, 255, 255, 0.22);
  border-radius: 18rpx;
  border: 2rpx solid rgba(105, 131, 95, 0.22);
  box-shadow: inset 0 2rpx 8rpx rgba(255, 255, 255, 0.35);
  transition: background 0.45s ease, box-shadow 0.45s ease;
}

.record-week-bar.goal-met-glow {
  background: linear-gradient(180deg, rgba(255, 248, 220, 0.95) 0%, rgba(255, 224, 150, 0.88) 100%) !important;
  border-color: rgba(212, 175, 55, 0.55);
  animation: goalMetPanelPulse 2.4s ease-in-out infinite;
  box-shadow: inset 0 2rpx 10rpx rgba(255, 255, 255, 0.5), 0 4rpx 16rpx rgba(180, 130, 40, 0.25);
}

@keyframes goalMetPanelPulse {
  0%,
  100% {
    filter: brightness(1);
    opacity: 1;
  }
  50% {
    filter: brightness(1.08);
    opacity: 0.94;
  }
}

.record-day-slot {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  min-width: 0;
}

.record-day-future {
  opacity: 0.38;
  pointer-events: none;
}

.record-day-label {
  font-size: 22rpx;
  font-weight: 800;
  color: #3d4a33;
}

.record-day-circle-wrap {
  position: relative;
  display: flex;
  justify-content: center;
  width: 100%;
}

.record-day-trophy {
  position: absolute;
  top: -28rpx;
  font-size: 28rpx;
  line-height: 1;
}

.record-day-circle {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: linear-gradient(165deg, #d8e2cc 0%, #c5ceb8 100%);
  border: 4rpx solid #8a9a7a;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 8rpx rgba(38, 62, 35, 0.12);
}

.record-day-today {
  border-color: #2e5b3b;
  box-shadow: 0 0 0 2rpx rgba(46, 91, 59, 0.35);
}

.record-day-won {
  background: linear-gradient(165deg, #6fd06f 0%, #4caf50 100%);
  border-color: #2e7d32;
  box-shadow: 0 4rpx 10rpx rgba(46, 125, 50, 0.35);
}

.record-day-check {
  color: #fff;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1;
}

.record-day-modal-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.record-day-modal {
  position: relative;
  width: 100%;
  max-width: 560rpx;
  padding: 48rpx 36rpx 40rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.record-day-modal-win {
  background: linear-gradient(180deg, #d4f5c8 0%, #b8e6a8 100%);
}

.record-day-modal-lose {
  background: linear-gradient(180deg, #ffd4d4 0%, #f0a8a8 100%);
}

.record-day-modal-close {
  position: absolute;
  right: 16rpx;
  top: 12rpx;
  font-size: 40rpx;
  color: #b32b2b;
  padding: 8rpx 16rpx;
  line-height: 1;
}

.record-day-modal-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #2a3324;
}

.record-day-modal-score {
  font-size: 120rpx;
  font-weight: 900;
  line-height: 1.1;
  color: #1e2a18;
}

.record-day-modal-emoji {
  font-size: 64rpx;
  align-self: flex-start;
  margin-left: 8rpx;
}

.main-score {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0 4rpx;
}

.main-score-row {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 8rpx 12rpx 12rpx;
  box-sizing: border-box;
  min-height: 200rpx;
}

.main-score-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 0 0 auto;
  min-width: 0;
}

.ai-analyze-col {
  position: absolute;
  right: 12rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  flex-shrink: 0;
}

.ai-analyze-btn {
  width: 90rpx;
  height: 90rpx;
  flex-shrink: 0;
  border-radius: 22rpx;
  border: 3rpx solid #3a3a3a;
  background: linear-gradient(180deg, #8fef6a 0%, #4dc93a 100%);
  box-shadow: 8rpx 8rpx 16rpx rgba(0, 0, 0, 0.38);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-analyze-caption {
  font-size: 22rpx;
  font-weight: 700;
  color: #3d4a33;
  text-align: right;
  line-height: 1.35;
  max-width: 160rpx;
  white-space: pre-line;
}

.ai-analyze-icon {
  width: 54rpx;
  height: 66rpx;
  border-radius: 10rpx;
  border: 2rpx solid #2d7a32;
  background: linear-gradient(165deg, #b8f5a8 0%, #6fd06f 100%);
  box-shadow: inset 0 2rpx 4rpx rgba(255, 255, 255, 0.65), 0 4rpx 6rpx rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.ai-analyze-icon::after {
  content: "";
  position: absolute;
  top: 0;
  right: 0;
  width: 18rpx;
  height: 18rpx;
  background: linear-gradient(135deg, #e8ffd8 0%, #7bc96f 100%);
  border-left: 2rpx solid #2d7a32;
  border-bottom: 2rpx solid #2d7a32;
  border-bottom-left-radius: 6rpx;
}

.ai-analyze-icon-ai {
  font-size: 34rpx;
  font-weight: 900;
  color: #1a5c22;
  letter-spacing: 2rpx;
}

.goal-tip {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 36rpx;
  font-weight: 700;
  border-radius: 18rpx;
  padding: 10rpx 14rpx;
  background: rgba(255, 255, 255, 0.38);
  border: 2rpx solid rgba(105, 131, 95, 0.28);
  box-shadow: 0 6rpx 12rpx rgba(38, 62, 35, 0.08);
}

.goal {
  font-size: 52rpx;
}

.situation {
  font-size: 32rpx;
  color: #64764e;
}

.goal-setting-btn {
  margin-left: auto;
  color: #2e5b3b;
  background: rgba(255, 255, 255, 0.4);
  border-radius: 10rpx;
  padding: 4rpx 10rpx;
}

.score {
  font-size: 128rpx;
  line-height: 1;
  letter-spacing: 2rpx;
  text-shadow: 0 3rpx 0 rgb(255, 255, 255);
}

.score-caption {
  margin-top: -10rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.62);
}

.username {
  font-size: 40rpx;
}

.recent-act-list {
  margin-top: 18rpx;
  padding: 16rpx 14rpx;
  backdrop-filter: blur(4rpx);
  border-radius: 8rpx;
}

.recent-body {
  overflow: hidden;
  transition: max-height 0.45s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease, margin 0.35s ease;
}

.recent-body-open {
  max-height: 2400rpx;
  opacity: 1;
  margin-top: 0;
}

.recent-body-closed {
  max-height: 0;
  opacity: 0;
  margin-top: 0;
  pointer-events: none;
}

.recent-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
  font-size: 36rpx;
  font-weight: 700;
}

.list-close-btn {
  padding: 0 12rpx;
}

.recent-empty-hint {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 20rpx 12rpx 8rpx;
}

.recent-empty-line {
  font-size: 30rpx;
  line-height: 1.45;
  color: #3d4a33;
  font-weight: 600;
}

.do-list-panel {
  margin-top: 20rpx;
  padding: 14rpx;
}

.do-list-panel > .high-rate-act {
  background: #3d6b2e;
  border-radius: 20rpx;
  padding: 14rpx 12rpx 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 6rpx 12rpx rgba(0, 0, 0, 0.12);
}

.high-rate-act-label {
  display: inline-block;
  font-size: 24rpx;
  color: #e8f5d0;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 999rpx;
  padding: 6rpx 16rpx;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.do-list-panel > .high-rate-act > .high-rate-act {
  display: grid;
  grid-template-columns: 1fr 2fr;
  margin-bottom: 8rpx;
  border: 3rpx solid #7a8b68;
  border-radius: 14rpx;
  overflow: hidden;
  min-width: 0;
}

.do-list-panel > .high-rate-act > .high-rate-act:last-child {
  margin-bottom: 0;
}

.do-list-panel > .high-rate-act > .high-rate-act text {
  min-width: 0;
  min-height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  padding: 0 6rpx;
  box-sizing: border-box;
  font-weight: 700;
  background: rgba(224, 252, 177, 0.86);
  border-right: 2rpx solid #9cb189;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.do-list-panel > .high-rate-act > .high-rate-act text:last-child {
  border-right: none;
}

.high-rate-act-disabled {
  opacity: 0.45;
}

.entry-btns {
  display: flex;
  gap: 16rpx;
}

.entry-btn {
  flex: 1;
  min-height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 42rpx;
  font-weight: 700;
  background: rgba(240, 255, 219, 0.86);
}

.entry-btn .icon-emoji {
  font-size: 104rpx;
  line-height: 1;
}
