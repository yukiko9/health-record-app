.screen.sleep-night-block {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

.sleep-night-block {
  background: linear-gradient(180deg, #bb7dff 0%, #8300e5 35%, #333333 100%);
  color: #111;
}

.top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.return-btn {
  min-width: 110rpx;
  text-align: center;
  padding: 8rpx 0;
}

.score-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.score {
  font-size: 90rpx;
}

.score-caption {
  font-size: 28rpx;
  color: rgba(244, 244, 244, 0.78);
  font-weight: 700;
}

.sleep-main {
  flex: 1;
  min-height: 0;
  margin-top: 24rpx;
  display: flex;
  gap: 20rpx;
  align-items: stretch;
}

.sleep-mode-btn {
  width: 170rpx;
  min-height: 320rpx;
  padding: 12rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  font-size: 42rpx;
  font-weight: 700;
  background: #cc8efc;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.18);
  border: 3rpx solid rgba(255, 255, 255, 0.35);
}

.sleep-control {
  flex: 1;
  display: grid;
  grid-template-columns: 80rpx 1fr 80rpx;
  gap: 10rpx;
  align-items: center;
}

.sleep-hour-reduce,
.sleep-hour-add {
  height: 220rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 70rpx;
  background: #facd91;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.12);
}

.sleep-hour {
  min-height: 140rpx;
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 90rpx;
  font-weight: 700;
  background: #cc8efc;
  border-radius: 18rpx;
  box-shadow: inset 0 2rpx 6rpx rgba(255, 255, 255, 0.25);
}

.sleep-half-hour {
  grid-column: 2 / 3;
}

.sleep-scene {
  margin-top: auto;
  padding: 32rpx 0 24rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  font-size: 112rpx;
}
