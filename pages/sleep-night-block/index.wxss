.screen.sleep-night-block {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

.sleep-night-block {
  background: linear-gradient(180deg, #c9a6ff 0%, #8b3dff 32%, #2a1840 72%, #1a1228 100%);
  color: #111;
}

.top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.return-btn {
  min-width: 110rpx;
  text-align: center;
  padding: 8rpx 0;
}

.score-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.score {
  font-size: 90rpx;
}

.score-caption {
  font-size: 28rpx;
  color: rgba(244, 244, 244, 0.78);
  font-weight: 700;
}

.sleep-main {
  flex: 1;
  min-height: 0;
  margin-top: 24rpx;
  display: flex;
  gap: 20rpx;
  align-items: stretch;
}

.sleep-mode-btn {
  width: 170rpx;
  height: 500rpx;
  padding: 12rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  text-align: center;
  align-items: center;
  gap: 8rpx;
  font-size: 48rpx;
  font-weight: 700;
  background: #cc8efc;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.18);
  border: 3rpx solid rgba(255, 255, 255, 0.35);
}

.sleep-control {
  flex: 1;
  display: grid;
  grid-template-columns: minmax(88rpx, 1fr) auto minmax(88rpx, 1fr);
  grid-template-rows: auto auto;
  gap: 16rpx 12rpx;
  align-items: center;
}

.sleep-hour-reduce {
  grid-column: 1;
  grid-row: 1;
  justify-self: stretch;
  min-height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 70rpx;
  background: #facd91;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.12);
  padding-right: 24rpx;
  box-sizing: border-box;
}

.sleep-hour-add {
  grid-column: 3;
  grid-row: 1;
  justify-self: stretch;
  min-height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 70rpx;
  background: #facd91;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.12);
  padding-left: 24rpx;
  box-sizing: border-box;
}

.sleep-hour {
  grid-column: 2;
  grid-row: 1;
  justify-self: center;
  align-self: center;
  min-height: 140rpx;
  height: 140rpx;
  width: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 90rpx;
  font-weight: 700;
  background: #cc8efc;
  border-radius: 18rpx;
  box-shadow: inset 0 2rpx 6rpx rgba(255, 255, 255, 0.25);
}

.sleep-save-btn {
  grid-column: 1 / -1;
  grid-row: 2;
  width: 100%;
  min-height: 96rpx;
  line-height: 1.2;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
}

.sleep-buddy-card {
  margin-top: auto;
  margin-left: -24rpx;
  margin-right: -24rpx;
  align-self: stretch;
  box-sizing: border-box;
  padding: 20rpx 18rpx 28rpx;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}



.sleep-buddy-img {
  display: block;
  width: 100%;
  height: auto;
  border-radius: 0;
}

.sleep-buddy-note {
  font-size: 26rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #2a1840;
  text-align: center;
  padding: 0 12rpx;
}

.sleep-night-block .sleep-mode-btn .icon-emoji {
  text-align: center;
  font-size: 56rpx;
}

.sleep-night-block .mood-emoji.icon-emoji {
  font-size: 80rpx;
}
