.screen.sleep-noon-block {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

.sleep-noon-block {
  background: linear-gradient(180deg, #b8ecff 0%, #d8f4fc 45%, #e8f8fc 100%);
  color: #111;
}

.top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.return-btn {
  min-width: 110rpx;
  text-align: center;
  padding: 8rpx 0;
}

.score-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.score {
  font-size: 90rpx;
}

.score-caption {
  font-size: 28rpx;
  color: rgba(29, 46, 55, 0.62);
  font-weight: 700;
}

.sleep-main {
  flex: 1;
  min-height: 0;
  margin-top: 24rpx;
  display: flex;
  gap: 20rpx;
  align-items: stretch;
}

.sleep-mode-btn {
  width: 170rpx;
  min-height: 320rpx;
  padding: 12rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  font-size: 42rpx;
  font-weight: 700;
  background: #d9f7af;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 16rpx rgba(46, 91, 59, 0.12);
  border: 3rpx solid rgba(255, 255, 255, 0.55);
}

.sleep-control {
  flex: 1;
  display: grid;
  grid-template-columns: 80rpx 1fr 80rpx;
  gap: 10rpx;
  align-items: center;
}

.sleep-hour-reduce,
.sleep-hour-add {
  height: 220rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 70rpx;
  background: #facd91;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 10rpx rgba(46, 91, 59, 0.1);
}

.sleep-hour {
  min-height: 140rpx;
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 90rpx;
  font-weight: 700;
  background: #d9f7af;
  border-radius: 18rpx;
  box-shadow: inset 0 2rpx 6rpx rgba(255, 255, 255, 0.4);
}

.sleep-half-hour {
  grid-column: 2 / 3;
}

.sleep-buddy-card {
  margin-top: auto;
  padding: 20rpx 18rpx 28rpx;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.sleep-buddy-noon {
  background: rgba(30, 48, 58, 0.88);
  border: 6rpx solid #1a2830;
  box-shadow: 0 12rpx 28rpx rgba(20, 40, 55, 0.28);
}

.sleep-buddy-img {
  width: 100%;
  max-width: 520rpx;
  height: 280rpx;
  border-radius: 18rpx;
}

.sleep-buddy-note {
  font-size: 26rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #e8f8fc;
  text-align: center;
  padding: 0 12rpx;
}

.sleep-noon-block .sleep-mode-btn .icon-emoji {
  font-size: 58rpx;
}

.sleep-noon-block .mood-emoji.icon-emoji {
  font-size: 82rpx;
}
