.screen.eating-block {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

.eating-block .mood-emoji.icon-emoji {
  font-size: 88rpx;
}

.eating-block {
  background: transparent;
}

.top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.return-btn {
  min-width: 200rpx;
  text-align: center;
  padding: 8rpx 0;
}

.score-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.score {
  font-size: 90rpx;
}

.score-caption {
  font-size: 28rpx;
  color: rgba(27, 35, 22, 0.62);
  font-weight: 700;
}

.content {
  flex: 1;
  min-height: 0;
  margin-top: 20rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.menu {
  flex-shrink: 0;
  width: 156rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.menu-btn.balanced-food-btn,
.menu-btn.junk-food-btn,
.menu-btn.water-food-btn {
  height: 80px;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.eating-content-right {
  flex: 1;
  min-width: 0;
  width: 0;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  align-self: stretch;
  gap: 12rpx;
  box-sizing: border-box;
}

.menu-btn {
  padding: 16rpx 8rpx;
  text-align: center;
  font-weight: 700;
  font-size: 26rpx;
  line-height: 1.35;
  background: rgba(217, 247, 175, 0.96) !important;
  border: 3rpx solid rgba(80, 90, 72, 0.55) !important;
  border-radius: 20rpx !important;
  box-shadow: 0 10rpx 8rpx rgba(0, 0, 0, 0.18);
  backdrop-filter: blur(2rpx);
}

/* 侧栏菜单选中：持续左右晃动 */
.menu-btn-selected {
  transform: translateY(4rpx);
  box-shadow: inset 0 6rpx 12rpx rgba(38, 62, 35, 0.22), 0 2rpx 4rpx rgba(255, 255, 255, 0.35);
  filter: brightness(0.97);
  animation: menuSideWiggleEat 0.48s ease-in-out infinite;
}

@keyframes menuSideWiggleEat {
  0%,
  100% {
    transform: translateY(4rpx) translateX(0);
  }
  50% {
    transform: translateY(4rpx) translateX(3rpx);
  }
}

.eating-data-input {
  flex: 1;
  min-width: 0;
  width: 100%;
  max-width: 100%;
  padding: 20rpx 16rpx;
  border-width: 3rpx;
  box-sizing: border-box;
  box-shadow: inset 0 2rpx 12rpx rgba(255, 255, 255, 0.45);
}

.eating-data-input-lined {
  background-color: rgba(255, 255, 255, 0.88);
  background-image: repeating-linear-gradient(
    to bottom,
    rgba(72, 72, 72, 0.18) 0,
    rgba(72, 72, 72, 0.18) 1px,
    transparent 1px,
    transparent 50px
  );
  background-size: 100% 50px;
  background-origin: padding-box;
  background-repeat: repeat;
}

.panel-user-note {
  position: relative;
  z-index: 1;
  display: block;
  font-size: 50px;
  line-height: 1.35;
  min-height: 100px;
  margin-top: 20rpx;
  padding: 12px 8px 20px;
  color: #2e3238;
  font-weight: 600;
  white-space: pre-wrap;
}

.save-eat-btn,
.reset-eat-btn {
  min-height: 108rpx !important;
  padding-top: 22rpx !important;
  padding-bottom: 22rpx !important;
  line-height: 1.25 !important;
}

.bottom-btns {
  margin-top: auto;
  padding-top: 24rpx;
  padding-bottom: 8rpx;
  display: flex;
  gap: 16rpx;
}

.bottom-btns button {
  flex: 1;
}

@keyframes eating-panel-bump {
  0% {
    transform: translateY(0);
  }
  35% {
    transform: translateY(-14rpx);
  }
  65% {
    transform: translateY(4rpx);
  }
  100% {
    transform: translateY(0);
  }
}

.eating-panel-bump {
  animation: eating-panel-bump 0.42s cubic-bezier(0.34, 1.2, 0.64, 1) 1;}