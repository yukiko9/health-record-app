.screen.eating-block {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

.eating-block .mood-emoji.icon-emoji {
  font-size: 88rpx;
}

.eating-block {
  background: transparent;
}

.top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.return-btn {
  min-width: 110rpx;
  text-align: center;
  padding: 8rpx 0;
}

.score-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.score {
  font-size: 90rpx;
}

.score-caption {
  font-size: 28rpx;
  color: rgba(27, 35, 22, 0.62);
  font-weight: 700;
}

.content {
  flex: 1;
  min-height: 0;
  margin-top: 20rpx;
  display: flex;
  gap: 16rpx;
}

.menu {
  width: 156rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.menu-btn {
  padding: 16rpx 8rpx;
  text-align: center;
  font-weight: 700;
  font-size: 26rpx;
  line-height: 1.35;
  background: rgba(217, 247, 175, 0.96) !important;
  border: 3rpx solid rgba(80, 90, 72, 0.55) !important;
  border-radius: 20rpx !important;
  box-shadow: 0 10rpx 8rpx rgba(0, 0, 0, 0.18);
  backdrop-filter: blur(2rpx);
}

.menu-btn-selected {
  transform: translateY(4rpx);
  box-shadow: inset 0 6rpx 12rpx rgba(38, 62, 35, 0.22), 0 2rpx 4rpx rgba(255, 255, 255, 0.35);
  filter: brightness(0.97);
}

.eating-data-input {
  flex: 1;
  min-width: 0;
  padding: 20rpx 16rpx;
  border-width: 3rpx;
  box-shadow: inset 0 2rpx 12rpx rgba(255, 255, 255, 0.45);
}

.bottom-btns {
  margin-top: auto;
  padding-top: 24rpx;
  padding-bottom: 8rpx;
  display: flex;
  gap: 16rpx;
}

.bottom-btns button {
  flex: 1;
}

@keyframes eating-panel-bump {
  0% {
    transform: translateY(0);
  }
  35% {
    transform: translateY(-14rpx);
  }
  65% {
    transform: translateY(4rpx);
  }
  100% {
    transform: translateY(0);
  }
}

.eating-panel-bump {
  animation: eating-panel-bump 0.42s cubic-bezier(0.34, 1.2, 0.64, 1) 1;}