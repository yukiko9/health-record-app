page {
  background: #e8f5c8;
  color: #2e3238;
  min-height: 100%;
  font-family: "幼圆", "YouYuan", "Yuanti SC", "Microsoft YaHei", "PingFang SC", Arial, sans-serif;
}

.screen {
  box-sizing: border-box;
  position: relative;
  z-index: 1;
  width: 100%;
  min-height: 100vh;
  padding: 24rpx;
}

.screen::before {
  content: "";
  display: block;
  height: 36rpx;
  margin: -4rpx -12rpx 16rpx -12rpx;
  border-radius: 12rpx;
  background-image: radial-gradient(circle at 50% 50%, rgba(55, 55, 55, 0.75) 9rpx, transparent 10rpx);
  background-size: 40rpx 36rpx;
  background-repeat: repeat-x;
  background-position: 18rpx 50%;
  opacity: 0.42;
  pointer-events: none;
}

.card {
  background: rgba(240, 255, 219, 0.86);
  border: 5px solid rgba(105, 131, 95, 0.72);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 18rpx rgba(38, 62, 35, 0.16);
}

.label-strong {
  font-weight: 700;
  color: #111;
}

.btn-primary {
  background: linear-gradient(180deg, #61f751 0%, #41db37 100%);
  color: #173812;
  border-radius: 20rpx;
  border: 5px solid #3cae44;
  font-size: 42rpx;
  font-weight: 700;
}

.btn-disabled {
  opacity: 0.55;
}

.btn-danger {
  background: linear-gradient(180deg, #f0929d 0%, #ec808d 100%);
  color: #6b252d;
  border-radius: 20rpx;
  border: 5px solid #b66470;
  font-size: 42rpx;
  font-weight: 700;
}

.icon-emoji {
  font-size: 72rpx;
  line-height: 1.1;
}

.mood-emoji.icon-emoji {
  font-size: 88rpx;
}

button {
  transition: transform 120ms ease, box-shadow 120ms ease, filter 120ms ease;
  box-shadow: 0 8rpx 12rpx rgba(0, 0, 0, 0.14);
}

button::after {
  border: none;
}

button:active {
  transform: scale(0.97) translateY(1rpx);
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.15);
  filter: brightness(0.96);
}

.pressable {
  transition: transform 120ms ease, box-shadow 120ms ease, filter 120ms ease;
}

.pressing {
  transform: scale(0.97) translateY(1rpx);
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.12);
  filter: brightness(0.98);
}

@keyframes scoreEntryBump {
  0% {
    transform: translateY(10rpx) scale(0.992);
    opacity: 0.94;
  }
  58% {
    transform: translateY(-8rpx) scale(1.006);
    opacity: 1;
  }
  100% {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
}

.score-bump-wrap {
  display: inline-block;
  vertical-align: middle;
}

.score-entry-bump {
  animation: scoreEntryBump 0.44s cubic-bezier(0.34, 1.18, 0.64, 1) forwards;
}

@keyframes scoreNudgeHint {
  0%,
  72% {
    transform: rotate(0deg);
  }
  74% {
    transform: rotate(-2.2deg);
  }
  77% {
    transform: rotate(2.2deg);
  }
  80% {
    transform: rotate(-1.4deg);
  }
  83% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(0deg);
  }
}

.score-nudge-hint {
  display: inline-block;
  animation: scoreNudgeHint 3s ease-in-out infinite;
}

@keyframes mainPageBgBreathe {
  0%,
  100% {
    opacity: 1;
  }
  50% {
    opacity: 0.75;
  }
}

@keyframes btnWiggle {
  0%,
  100% {
    transform: translateX(0);
  }
  33% {
    transform: translateX(-5rpx);
  }
  66% {
    transform: translateX(5rpx);
  }
}

.btn-wiggle-active {
  animation: btnWiggle 0.32s ease-in-out infinite;
}
