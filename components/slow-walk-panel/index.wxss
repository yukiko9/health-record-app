.metric-panel {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 10rpx 4rpx 12rpx;
}

.metric-card {
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 18rpx rgba(45, 90, 45, 0.18);
  border: 2rpx solid rgba(255, 255, 255, 0.45);
}

.metric-card-active .metric-card-head {
  background: linear-gradient(180deg, #3b82c4 0%, #2563a8 100%);
  color: #fff;
}

.metric-card-muted .metric-card-head {
  background: #b8c4d4;
  color: #5a6570;
}

.metric-card-muted .metric-card-body {
  opacity: 0.55;
  background: #eef2f6;
}

.metric-card-active .metric-card-body {
  background: #fff;
}

.metric-card-head {
  font-size: 28rpx;
  font-weight: 800;
  padding: 14rpx 20rpx;
  letter-spacing: 2rpx;
}

.metric-card-body {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 20rpx;
}

.metric-input {
  flex: 1;
  min-height: 72rpx;
  border: 2rpx solid #94b8d4;
  border-radius: 12rpx;
  padding: 0 16rpx;
  font-size: 34rpx;
  font-weight: 700;
  background: #fff;
}

.metric-unit {
  font-size: 28rpx;
  font-weight: 700;
  color: #3d5a73;
  min-width: 48rpx;
}
