.panel {
  padding: 14rpx 12rpx;
  border: 3rpx solid rgba(90, 110, 78, 0.55);
  border-radius: 20rpx;
  background: rgba(224, 252, 177, 0.92);
  box-shadow: 0 8rpx 20rpx rgba(38, 62, 35, 0.12);
}

.food-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 2rpx solid rgba(121, 144, 106, 0.85);
  border-radius: 14rpx;
  padding: 12rpx 14rpx;
  margin-bottom: 10rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.35);
}

.food-item-on {
  animation: foodItemWiggle 0.48s ease-in-out infinite;
}

@keyframes foodItemWiggle {
  0%,
  100% {
    transform: translateX(0);
  }
  50% {
    transform: translateX(4rpx);
  }
}

.fullness-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 2rpx solid rgba(121, 144, 106, 0.85);
  border-radius: 14rpx;
  padding: 10rpx 14rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.4);
  box-shadow: inset 0 2rpx 4rpx rgba(255, 255, 255, 0.4);
}

.n {
  font-size: 42rpx;
}
