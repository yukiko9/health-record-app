.panel {
  padding: 14rpx 12rpx;
  border: 3rpx solid rgba(70, 120, 110, 0.45);
  border-radius: 20rpx;
  background: linear-gradient(180deg, #e8fce0 0%, rgba(200, 240, 190, 0.95) 100%);
  box-shadow: 0 8rpx 20rpx rgba(38, 90, 70, 0.12);
  font-size: 28rpx;
}

.food-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 50px;
  border: 2rpx solid rgba(90, 130, 100, 0.75);
  border-radius: 14rpx;
  padding: 0 14rpx;
  margin-bottom: 10rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.45);
}

.food-item text {
  font-size: 28rpx;
  line-height: 1.2;
}

.food-item text:last-child {
  font-size: 34rpx;
}

.food-item-on {
  animation: foodItemWiggle 0.8s ease-in-out 1 forwards;
}

@keyframes foodItemWiggle {
  0%,
  100% {
    transform: translateX(0);
  }
  50% {
    transform: translateX(4rpx);
  }
}

.fullness-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 50px;
  border: 2rpx solid rgba(90, 130, 100, 0.65);
  border-radius: 14rpx;
  padding: 0 14rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.5);
}

.fullness-btn text {
  font-size: 28rpx;
}

.n {
  font-size: 36rpx;
}
