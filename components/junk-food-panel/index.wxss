.panel {
  padding: 14rpx 12rpx;
  border: 3rpx solid rgba(120, 70, 80, 0.45);
  border-radius: 20rpx;
  background: linear-gradient(180deg, #f8c4cb 0%, #f3b3bc 100%);
  box-shadow: 0 8rpx 20rpx rgba(90, 40, 50, 0.15);
}

.food-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 2rpx solid rgba(120, 70, 80, 0.55);
  border-radius: 14rpx;
  padding: 12rpx 14rpx;
  margin-bottom: 10rpx;
  font-weight: 700;
  background: rgba(236, 128, 141, 0.92);
}

.fullness-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 2rpx solid rgba(120, 70, 80, 0.5);
  border-radius: 14rpx;
  padding: 10rpx 14rpx;
  font-weight: 700;
  background: #f8cd91;
  box-shadow: inset 0 2rpx 4rpx rgba(255, 255, 255, 0.35);
}

.n {
  font-size: 42rpx;
}
