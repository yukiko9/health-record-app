.bubble-layer {
  pointer-events: none;
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 100vh;
  z-index: 0;
  overflow: hidden;
}

.bubble {
  position: absolute;
  bottom: -120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  backdrop-filter: blur(2rpx);
  animation-name: bubble-rise;
  animation-iteration-count: infinite;
  animation-timing-function: linear;
}

.bubble-a {
  width: 34rpx;
  height: 34rpx;
  left: 8%;
  animation-duration: 8.4s;
}

.bubble-b {
  width: 56rpx;
  height: 56rpx;
  left: 22%;
  animation-duration: 9.2s;
  animation-delay: 1.2s;
}

.bubble-c {
  width: 28rpx;
  height: 28rpx;
  left: 40%;
  animation-duration: 7.8s;
  animation-delay: 2.8s;
}

.bubble-d {
  width: 46rpx;
  height: 46rpx;
  left: 58%;
  animation-duration: 8.8s;
  animation-delay: 2.1s;
}

.bubble-e {
  width: 64rpx;
  height: 64rpx;
  left: 72%;
  animation-duration: 10.1s;
  animation-delay: 0.8s;
}

.bubble-f {
  width: 36rpx;
  height: 36rpx;
  left: 88%;
  animation-duration: 9.6s;
  animation-delay: 3.2s;
}

@keyframes bubble-rise {
  0% {
    transform: translateY(0) scale(0.9);
    opacity: 0;
  }
  10% {
    opacity: 0.7;
  }
  85% {
    opacity: 0.45;
  }
  100% {
    transform: translateY(-80vh) scale(1.05);
    opacity: 0;
  }
}
