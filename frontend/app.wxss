page {
  background: #e8f5c8;
  color: #2e3238;
  min-height: 100vh;
  height: auto;
  font-family: "幼圆", "YouYuan", "Yuanti SC", "Microsoft YaHei", "PingFang SC", Arial, sans-serif;
}

/*
 * Nunito 仅 0–9 子集（体积小）；配合 unicode-range 仅数字用该字体，汉字仍走后续系统/幼圆。
 * 许可见 fonts/Nunito-OFL.txt；app.js 中 loadFontFace 注册同名族。
 */
@font-face {
  font-family: "NunitoDigits";
  font-style: normal;
  font-weight: 700;
  font-display: swap;
  unicode-range: U+30-39;
  src: url("/fonts/Nunito-Digits.woff2") format("woff2");
}

.screen {
  box-sizing: border-box;
  position: relative;
  z-index: 1;
  width: 100%;
  min-height: 100vh;
  /* 顶边无内边距：顶端装饰可与胶囊重叠；左右下保持 24rpx */
  padding: 0 24rpx 24rpx;
}

/* 除 goal-setting 外：主内容区整体下移 60px；底栏请放在此节点外以免被顶下去 */
.shift-content-down-60 {
  padding-top: 80px;
  box-sizing: border-box;
}

/* 活动/饮食页：胶囊下沿以下的主体列 */
.screen-page-body {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.sleep-page-body {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.sleep-upper-wrap {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* 排钉：绝对定位不占流式高度，避免把下方顶栏整块挤下去（act/eating） */
.screen::before {
  content: "";
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  top: calc(20rpx + 40px);
  height: 36rpx;
  margin: 0;
  border-radius: 12rpx;
  z-index: 10;
  box-sizing: border-box;
  display: block;
  background-image: linear-gradient(
      to top,
      rgba(20, 20, 20, 0.92) 0,
      rgba(20, 20, 20, 0.92) 42%,
      transparent 42%
    ),
    radial-gradient(circle at 50% 50%, rgba(55, 55, 55, 0.75) 9rpx, transparent 10rpx);
  background-size: 40rpx 36rpx, 40rpx 36rpx;
  background-repeat: repeat-x, repeat-x;
  background-position: 18rpx 50%, 18rpx 50%;
  opacity: 0.42;
  pointer-events: none;
}

/* 与背景呼吸层分离，避免随底层渐变/透明度变化产生「排钉隐现」观感 */
.binder-decor-layer {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  top: calc(20rpx + 40px);
  height: 36rpx;
  border-radius: 12rpx;
  z-index: 10;
  box-sizing: border-box;
  background-image: linear-gradient(
      to top,
      rgba(20, 20, 20, 0.92) 0,
      rgba(20, 20, 20, 0.92) 42%,
      transparent 42%
    ),
    radial-gradient(circle at 50% 50%, rgba(55, 55, 55, 0.75) 9rpx, transparent 10rpx);
  background-size: 40rpx 36rpx, 40rpx 36rpx;
  background-repeat: repeat-x, repeat-x;
  background-position: 18rpx 50%, 18rpx 50%;
  opacity: 0.42;
  pointer-events: none;
}

.main-ui.screen::before,
.enter-ui.screen::before,
.goal-setting.screen::before,
.sleep-night-block.screen::before,
.sleep-noon-block.screen::before {
  display: none;
}

.card {
  background: rgba(240, 255, 219, 0.86);
  border: 5px solid rgba(105, 131, 95, 0.72);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 18rpx rgba(38, 62, 35, 0.16);
}

.label-strong {
  font-weight: 700;
  color: #111;
}

.btn-primary {
  background: linear-gradient(180deg, #61f751 0%, #41db37 100%);
  color: #173812;
  border-radius: 20rpx;
  border: 5px solid #3cae44;
  font-size: 42rpx;
  font-weight: 700;
}

.btn-disabled {
  opacity: 0.55;
}

.btn-danger {
  background: linear-gradient(180deg, #f0929d 0%, #ec808d 100%);
  color: #6b252d;
  border-radius: 20rpx;
  border: 5px solid #b66470;
  font-size: 42rpx;
  font-weight: 700;
}

.icon-emoji {
  font-size: 72rpx;
  line-height: 1.1;
}

.mood-emoji.icon-emoji {
  font-size: 88rpx;
  animation: moodEmojiBump 2s ease-in-out infinite;
  text-shadow: 0 3rpx 14rpx rgba(0, 0, 0, 0.08);
}

@keyframes moodEmojiBump {
  0%,
  80%,
  100% {
    transform: translateY(0);
  }
  90% {
    transform: translateY(-4px);
  }
}

/* 数字、分数、输入与等宽数字：系统标准无衬线（正文汉字仍为 page 幼圆） */
.roller-root,
.roller-line,
.metric-input,
.metric-input-placeholder,
input,
textarea,
.duration,
text.duration,
.goal,
.goal-tip .goal,
.goal-tip-situation,
.enter-ui .goal,
.enter-ui .situation,
.goal-ten-digits,
.goal-single-digits,
.sleep-hour,
.sleep-hour text,
.sleep-hour-add,
.sleep-hour-reduce,
.fullness-btn .n,
.ai-analyze-icon-ai,
.record-day-label {
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", "Microsoft YaHei", Arial, sans-serif;
  font-variant-numeric: tabular-nums;
}

.roller-line,
.metric-input,
.duration,
text.duration,
.goal,
.goal-tip .goal,
.goal-ten-digits,
.goal-single-digits,
.sleep-hour,
.sleep-hour text,
.sleep-hour-add,
.sleep-hour-reduce,
.fullness-btn .n,
.ai-analyze-icon-ai {
  font-weight: 700;
}

/* 分数文本：鲜橙色；数字用 NunitoDigits 子集，其余字形走后续字体 */
.score,
.record-day-modal-score {
  color: #ff8a00 !important;
  font-family: "NunitoDigits", "YouYuan", "幼圆", "PingFang SC", "Microsoft YaHei", Arial, sans-serif;
  font-weight: 700;
  text-shadow:
    0 1rpx 2rpx rgba(255, 255, 255, 0.4),
    0 4rpx 18rpx rgba(255, 120, 40, 0.12),
    0 3rpx 12rpx rgba(0, 0, 0, 0.06);
  animation: scoreNudgeHint 3s ease-in-out infinite;
}

/* rolling-score 根节点带 .score，子级 .roller-line 需单独指定（否则被全局 .roller-line 字体覆盖） */
.roller-root.score,
.roller-root.score .roller-line {
  font-family: "NunitoDigits", "YouYuan", "幼圆", "PingFang SC", "Microsoft YaHei", Arial, sans-serif;
  font-variant-numeric: tabular-nums;
  font-weight: 700;
}

button {
  transition: transform 120ms ease, box-shadow 120ms ease, filter 120ms ease;
  box-shadow: 0 8rpx 12rpx rgba(0, 0, 0, 0.14);
}

button::after {
  border: none;
}

button:active {
  transform: scale(0.97) translateY(1rpx);
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.15);
  filter: brightness(0.96);
}

.pressable {
  transition: transform 120ms ease, box-shadow 120ms ease, filter 120ms ease;
}

.pressing {
  transform: scale(0.97) translateY(1rpx);
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.12);
  filter: brightness(0.98);
}

@keyframes scoreEntryBump {
  0% {
    transform: translateY(10rpx) scale(0.992);
    opacity: 0.94;
  }
  58% {
    transform: translateY(-8rpx) scale(1.006);
    opacity: 1;
  }
  100% {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
}

.score-bump-wrap {
  display: inline-block;
  vertical-align: middle;
}

.score-entry-bump {
  animation: scoreEntryBump 0.44s cubic-bezier(0.34, 1.18, 0.64, 1) forwards;
}

@keyframes scoreNudgeHint {
  0%,
  72% {
    transform: rotate(0deg);
  }
  74% {
    transform: rotate(-2.2deg);
  }
  77% {
    transform: rotate(2.2deg);
  }
  80% {
    transform: rotate(-1.4deg);
  }
  83% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(0deg);
  }
}

.score-nudge-hint {
  display: inline-block;
}

@keyframes mainPageBgBreathe {
  0%,
  100% {
    opacity: 1;
  }
  50% {
    opacity: 0.75;
  }
}

@keyframes btnWiggle {
  0%,
  100% {
    transform: translateX(0);
  }
  33% {
    transform: translateX(-5rpx);
  }
  66% {
    transform: translateX(5rpx);
  }
}

.btn-wiggle-active {
  animation: btnWiggle 0.8s ease-in-out 1 forwards;
}
