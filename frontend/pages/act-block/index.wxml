<view class="screen act-block" style="{{pageBgStyle}}">
  <floating-bubbles />
  <view class="top">
    <view class="return-btn btn-danger pressable" bindtap="returnBtn" hover-class="pressing">←</view>
    <view class="score-wrap">
      <text class="mood-emoji icon-emoji">{{moodEmoji}}</text>
      <view class="score-bump-wrap {{scoreBump ? 'score-entry-bump' : ''}}">
        <rolling-score score-class="score label-strong" value="{{score}}" />
      </view>
    </view>
  </view>

  <view class="content">
    <view class="menu">
      <view class="menu-btn slow-walk-btn card pressable {{activePanel === 'slow-walk-panel' ? 'menu-btn-selected' : ''}}" data-panel="slow-walk-panel" bindtap="selectPanel" hover-class="pressing"><text>🚶 \n慢走</text></view>
      <view class="menu-btn fast-walk-btn card pressable {{activePanel === 'fast-walk-panel' ? 'menu-btn-selected' : ''}}" data-panel="fast-walk-panel" bindtap="selectPanel" hover-class="pressing"><text>🚶💦\n快走</text></view>
      <view class="menu-btn jog-btn card pressable {{activePanel === 'jog-panel' ? 'menu-btn-selected' : ''}}" data-panel="jog-panel" bindtap="selectPanel" hover-class="pressing"><text>🏃\n慢跑</text></view>
      <view class="menu-btn run-btn card pressable {{activePanel === 'run-panel' ? 'menu-btn-selected' : ''}}" data-panel="run-panel" bindtap="selectPanel" hover-class="pressing"><text>🏃💨\n中速/快跑</text></view>
      <view class="menu-btn sit-overtime-btn card pressable {{activePanel === 'sit-overtime-panel' ? 'menu-btn-selected' : ''}}" data-panel="sit-overtime-panel" bindtap="selectPanel" hover-class="pressing"><text>🪑\n久坐</text></view>
      <view class="menu-btn ride-btn card pressable {{activePanel === 'ride-panel' ? 'menu-btn-selected' : ''}}" data-panel="ride-panel" bindtap="selectPanel" hover-class="pressing"><text>🚴\n通勤骑行</text></view>
    </view>

    <view
      class="act-data-input act-data-input-lined card {{panelBump ? 'act-panel-bump' : ''}}"
      catchanimationend="onPanelBumpEnd"
    >
      <text class="act-panel-title" wx:if="{{activePanel === 'slow-walk-panel'}}">🚶 慢走</text>
      <text class="act-panel-title" wx:elif="{{activePanel === 'fast-walk-panel'}}">🚶💦 快走</text>
      <text class="act-panel-title" wx:elif="{{activePanel === 'jog-panel'}}">🏃 慢跑</text>
      <text class="act-panel-title" wx:elif="{{activePanel === 'run-panel'}}">🏃💨 中速/快跑</text>
      <text class="act-panel-title" wx:elif="{{activePanel === 'sit-overtime-panel'}}">🪑 久坐</text>
      <text class="act-panel-title" wx:elif="{{activePanel === 'ride-panel'}}">🚴 通勤骑行</text>
      <slow-walk-panel
        wx:if="{{activePanel === 'slow-walk-panel'}}"
        value="{{actDataInput}}"
        inputMode="{{actInputModes.slowWalk}}"
        reset-stamp="{{actResetStamp}}"
        bindchange="onSlowWalkChange"
      />
      <fast-walk-panel
        wx:if="{{activePanel === 'fast-walk-panel'}}"
        value="{{actDataInput}}"
        inputMode="{{actInputModes.fastWalk}}"
        reset-stamp="{{actResetStamp}}"
        bindchange="onFastWalkChange"
      />
      <jog-panel
        wx:if="{{activePanel === 'jog-panel'}}"
        value="{{actDataInput}}"
        inputMode="{{actInputModes.jog}}"
        reset-stamp="{{actResetStamp}}"
        bindchange="onJogChange"
      />
      <run-panel
        wx:if="{{activePanel === 'run-panel'}}"
        value="{{actDataInput}}"
        inputMode="{{actInputModes.run}}"
        reset-stamp="{{actResetStamp}}"
        bindchange="onRunChange"
      />
      <sit-overtime-panel
        wx:if="{{activePanel === 'sit-overtime-panel'}}"
        value="{{actDataInput}}"
        bindchange="onSitOvertimeChange"
      />
      <ride-panel
        wx:if="{{activePanel === 'ride-panel'}}"
        value="{{actDataInput}}"
        inputMode="{{actInputModes.ride}}"
        reset-stamp="{{actResetStamp}}"
        bindchange="onRideChange"
      />
      <text class="panel-user-note" selectable>😉活动记录功能\n是在距离和时间记录中\n二选一进行登记噢！\n😝后续可能继续更新更多活动类型！ </text>
    </view>
  </view>

  <view class="bottom-btns">
    <button class="save-act-btn btn-primary btn-wiggle-hover" bindtap="saveActBtn" hover-class="btn-wiggle-active">保存</button>
    <button class="reset-act-btn btn-danger btn-wiggle-hover" bindtap="resetActBtn" hover-class="btn-wiggle-active">重置</button>
  </view>
</view>
