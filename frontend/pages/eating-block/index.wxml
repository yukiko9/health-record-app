<view class="screen eating-block" style="{{pageBgStyle}}">
  <floating-bubbles />
  <view class="top">
    <view class="return-btn btn-danger pressable" bindtap="returnBtn" hover-class="pressing">←</view>
    <view class="score-wrap">
      <text class="mood-emoji icon-emoji">{{moodEmoji}}</text>
      <view class="score-bump-wrap {{scoreBump ? 'score-entry-bump' : ''}}">
        <rolling-score score-class="score label-strong" value="{{score}}" />
      </view>
    </view>
  </view>

  <view class="content">
    <view class="menu">
      <view class="menu-btn balanced-food-btn card pressable {{activePanel === 'balanced-food-panel' ? 'menu-btn-selected' : ''}}" data-panel="balanced-food-panel" bindtap="selectPanel" hover-class="pressing"><text>🥗\n健康饮食</text></view>
      <view class="menu-btn junk-food-btn card pressable {{activePanel === 'junk-food-panel' ? 'menu-btn-selected' : ''}}" data-panel="junk-food-panel" bindtap="selectPanel" hover-class="pressing"><text>🍔\n快餐/饮料</text></view>
      <view class="menu-btn water-food-btn card pressable {{activePanel === 'water-food-panel' ? 'menu-btn-selected' : ''}}" data-panel="water-food-panel" bindtap="selectPanel" hover-class="pressing"><text>🍎\n水/水果</text></view>
    </view>

    <view class="eating-content-right">
    <view
      class="eating-data-input eating-data-input-lined card {{panelBump ? 'eating-panel-bump' : ''}}"
      catchanimationend="onPanelBumpEnd"
    >
      <balanced-food-panel
        wx:if="{{activePanel === 'balanced-food-panel'}}"
        selectedMap="{{selectedMap}}"
        fullness="{{fullness}}"
        bindtoggle="onToggleItem"
        bindfullnesschange="onFullnessChange"
      />
      <junk-food-panel
        wx:if="{{activePanel === 'junk-food-panel'}}"
        selectedMap="{{selectedMap}}"
        fullness="{{fullness}}"
        milkteaSugar="{{milkteaSugar}}"
        bindtoggle="onToggleItem"
        bindfullnesschange="onFullnessChange"
        bindmilkteasugarchange="onMilkteaSugarChange"
      />
      <water-food-panel
        wx:if="{{activePanel === 'water-food-panel'}}"
        selectedMap="{{selectedMap}}"
        fullness="{{fullness}}"
        bindtoggle="onToggleItem"
        bindfullnesschange="onFullnessChange"
      />
      <text class="panel-user-note" selectable>如何描述你的饱食感：\n1：吃的很少🫠\n2：吃的还不够\n3：刚刚好😋\n4：吃的有点撑\n5：吃的非常撑！😈</text>
    </view>
    </view>
  </view>

  <view class="bottom-btns">
    <button class="save-eat-btn btn-primary btn-wiggle-hover" bindtap="saveEatBtn" hover-class="btn-wiggle-active">保存</button>
    <button class="reset-eat-btn btn-danger btn-wiggle-hover" bindtap="resetEatBtn" hover-class="btn-wiggle-active">重置</button>
  </view>
</view>
