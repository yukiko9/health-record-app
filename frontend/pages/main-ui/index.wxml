<view class="screen main-ui">
  <view class="page-bg-layer page-bg-breathe" style="{{pageBgStyle}}" />
  <view class="binder-decor-layer" aria-hidden="true" />
  <view class="main-ui-foreground">
  <view class="main-ui-shift-down">
  <floating-bubbles />
  <view class="header-panel">
    <view class="duration-panel card {{todayGoalMet ? 'goal-met-glow' : ''}}">
      <text class="duration-label">连胜天数</text>
      <text class="duration">{{duration}}</text>
    </view>

    <view class="record-week-bar card {{todayGoalMet ? 'goal-met-glow' : ''}}">
      <block wx:for="{{weekDays}}" wx:key="dateKey">
        <view
          class="record-day-slot {{item.isFuture ? 'record-day-future' : 'pressable'}}"
          bindtap="onRecordDayTap"
          data-key="{{item.dateKey}}"
          hover-class="{{item.isFuture ? '' : 'pressing'}}"
        >
          <text class="record-day-label">{{item.labelEn}}</text>
          <view class="record-day-circle-wrap">
            <view wx:if="{{item.showTrophy && item.won}}" class="record-day-trophy">🏆</view>
            <view class="record-day-circle {{item.won ? 'record-day-won' : ''}} {{item.isToday ? 'record-day-today' : ''}}">
              <text wx:if="{{item.won}}" class="record-day-check">✓</text>
            </view>
          </view>
        </view>
      </block>
    </view>

    <view wx:if="{{recordDayModalVisible}}" class="record-day-modal-mask" bindtap="closeRecordDayModal">
      <view
        class="record-day-modal card {{recordDayModalWon ? 'record-day-modal-win' : 'record-day-modal-lose'}} {{recordDayModalClosing ? 'record-day-modal-out' : 'record-day-modal-in'}}"
        catchtap="noopModal"
      >
        <view class="record-day-modal-bubbles"></view>
        <view class="record-day-modal-close pressable" bindtap="closeRecordDayModal" hover-class="pressing">✕</view>
        <text class="record-day-modal-title">{{recordDayModalTitle}}</text>
        <text class="record-day-modal-score">{{recordDayModalScore}}</text>
        <text class="record-day-modal-encourage">{{recordDayModalEncourage}}</text>
      </view>
    </view>
  </view>

  <view class="main-score">
    <view class="goal-tip pressable" bindtap="goGoalSetting" hover-class="pressing">
      <view class="goal-tip-track">
        <view class="goal-tip-fill" style="width: {{goalProgressPct}}%;">
          <view class="goal-tip-bubbles">
            <view class="goal-tip-bb goal-tip-bb1"></view>
            <view class="goal-tip-bb goal-tip-bb2"></view>
            <view class="goal-tip-bb goal-tip-bb3"></view>
            <view class="goal-tip-bb goal-tip-bb4"></view>
          </view>
          <view class="goal-tip-fill-edge"></view>
        </view>
        <view class="goal-tip-row {{goalProgressPct > 8 ? 'goal-tip-has-fill' : ''}}">
          <view class="goal-tip-left-cluster">
            <text class="goal-tip-label goal-tip-on-fill">目标:</text>
            <text class="goal goal-tip-on-fill">{{goal}}</text>
          </view>
          <text class="situation goal-tip-situation">{{situation}}</text>
          <text class="goal-setting-btn goal-tip-btn">设置</text>
        </view>
      </view>
    </view>

    <view class="main-score-row">
      <view class="main-score-col">
        <text class="mood-emoji icon-emoji">{{moodEmoji}}</text>
        <view class="score-bump-wrap {{scoreBump ? 'score-entry-bump' : ''}}">
          <view class="score-nudge-hint">
            <rolling-score score-class="score label-strong" value="{{score}}" />
          </view>
        </view>
      </view>
        <view class="ai-analyze-col">
          <view class="ai-analyze-btn pressable" bindtap="onAiAnalyzeTap" hover-class="pressing">
            <view class="ai-analyze-icon">
              <text class="ai-analyze-icon-ai">AI</text>
            </view>
          </view>
          <text class="ai-analyze-caption">截图读取\napp记录</text>
        </view>
    </view>
    <text class="username label-strong">{{username}}</text>
  </view>

  <view class="recent-act-list card">
    <view class="recent-head">
      <text>最近的活动:</text>
      <text class="list-close-btn pressable" bindtap="toggleRecentActList" hover-class="pressing">{{showRecentActList ? "◀" : "▶"}}</text>
    </view>
    <view class="recent-body {{showRecentActList ? 'recent-body-open' : 'recent-body-closed'}}">
      <view wx:if="{{recentActList.length === 0}}" class="recent-empty-hint">
        <text class="recent-empty-line">点击下面的三个模块开始记录你的活动！</text>
        <text class="recent-empty-line">每次保存记录都会更新你的健康分数！</text>
      </view>
      <recent-act-list-show wx:else list="{{recentActList}}" bind:deleterecord="deleteRecord" />
    </view>
  </view>

  <view class="do-list-panel card">
    <view class="high-rate-act">
      <text class="high-rate-act-label">你的高频记录...(点击会帮你进行重复记录！)</text>
      <block wx:for="{{highRateActList}}" wx:key="index">
        <view
          class="high-rate-act {{item.valid ? '' : 'high-rate-act-disabled'}} pressable"
          bindtap="onHighRateActTap"
          data-index="{{index}}"
          hover-class="{{item.valid ? 'pressing' : ''}}"
        >
          <text>{{item.do}}</text>
          <text>{{item.info}}</text>
        </view>
      </block>
    </view>
  <view class="entry-btns main-ui-entry-btns">
    <view class="entry-btn act-btn card pressable" bindtap="goActBlock" hover-class="pressing">
      <text class="icon-emoji">🏃</text>
      <text>活动</text>
    </view>
    <view class="entry-btn eating-btn card pressable" bindtap="goEatingBlock" hover-class="pressing">
      <text class="icon-emoji">🥄</text>
      <text>饮食</text>
    </view>
    <view class="entry-btn sleep-btn card pressable" bindtap="goSleepBlock" hover-class="pressing">
      <text class="icon-emoji">🛏️</text>
      <text>睡眠</text>
    </view>
  </view>
  </view>
  </view>
  </view>
</view>
