<view class="recent-act-list-show">
  <scroll-view class="recent-act-scroll" scroll-y>
    <block wx:for="{{list}}" wx:for-item="item" wx:for-index="idx" wx:key="idx">
      <view class="row">
        <view class="row-main">
          <text>{{item.do}}</text>
          <text>{{item.time}}</text>
          <text>{{item.info}}</text>
        </view>
        <button
          wx:if="{{item.id || item.localId}}"
          class="delete-record-btn"
          size="mini"
          catchtap="deleteRecord"
          data-index="{{idx}}"
          style="font-size: 10px;"
        >
          ❌
        </button>
      </view>
    </block>
  </scroll-view>
</view>
