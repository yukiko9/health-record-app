.recent-act-list-show {
  border: 4rpx solid #7e8d68;
  border-radius: 16rpx;
  overflow: hidden;
  background: rgba(224, 252, 177, 0.86);
}

/* 约两条数据行可视高度，其余滚动（scroll-view 需明确高度） */
.recent-act-scroll {
  height: 148rpx;
  width: 100%;
}

.row {
  display: flex;
  align-items: stretch;
  border-bottom: 2rpx solid #9cb189;
  min-width: 0;
}

.row-main {
  flex: 1;
  min-width: 0;
  display: grid;
  grid-template-columns: 1fr 1fr 2fr;
}

.row:last-child {
  border-bottom: none;
}

.row-main text {
  min-width: 0;
  min-height: 64rpx;
  line-height: 64rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  text-align: center;
  font-weight: 700;
  font-size: 30rpx;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", "Microsoft YaHei", Arial, sans-serif;
  font-variant-numeric: tabular-nums;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-main text:nth-child(3) {
  text-align: left;
  padding-left: 12rpx;
  padding-right: 12rpx;
}

.delete-record-btn {
  flex-shrink: 0;
  margin: 8rpx 8rpx 8rpx 0;
  padding: 0 12rpx;
  line-height: 48rpx;
  height: 48rpx;
  font-size: 22rpx;
  border: 2rpx solid #e57373;
  color: #b71c1c;
  background: rgba(255, 248, 248, 0.95);
  border-radius: 8rpx;
}
