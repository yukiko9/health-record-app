<view class="metric-panel jog-panel">
  <view
    class="metric-card {{!metricTouched ? 'metric-card-active' : (inputMode === 'distance' ? 'metric-card-active metric-card-nudge' : 'metric-card-muted')}}"
    bindtap="onPickDistance"
  >
    <view class="metric-card-head">距离</view>
    <view class="metric-card-body" catchtap="stopBubble">
      <input
        class="metric-input"
        type="number"
        value="{{distStr}}"
        placeholder="输入数字..."
        placeholder-class="metric-input-placeholder"
        bindinput="onDistanceInput"
        bindfocus="onPickDistance"
      />
      <text class="metric-unit">米</text>
    </view>
  </view>
  <view
    class="metric-card {{!metricTouched ? 'metric-card-active' : (inputMode === 'time' ? 'metric-card-active metric-card-nudge' : 'metric-card-muted')}}"
    bindtap="onPickTime"
  >
    <view class="metric-card-head">时间</view>
    <view class="metric-card-body" catchtap="stopBubble">
      <input
        class="metric-input"
        type="number"
        value="{{timeStr}}"
        placeholder="输入数字..."
        placeholder-class="metric-input-placeholder"
        bindinput="onTimeInput"
        bindfocus="onPickTime"
      />
      <text class="metric-unit">分</text>
    </view>
  </view>
</view>
