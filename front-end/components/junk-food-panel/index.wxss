.panel {
  padding: 14rpx 12rpx;
  border: 3rpx solid rgba(120, 70, 80, 0.45);
  border-radius: 20rpx;
  background: linear-gradient(180deg, #f8c4cb 0%, #f3b3bc 100%);
  box-shadow: 0 8rpx 20rpx rgba(90, 40, 50, 0.15);
  font-size: 28rpx;
}

.food-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 50px;
  border: 2rpx solid rgba(120, 70, 80, 0.55);
  border-radius: 14rpx;
  padding: 0 14rpx;
  margin-bottom: 10rpx;
  font-weight: 700;
  background: rgba(236, 128, 141, 0.92);
}

.food-item text {
  font-size: 28rpx;
  line-height: 1.2;
}

.food-item text:last-child {
  font-size: 34rpx;
}

.food-item-on {
  animation: foodItemWiggle 0.8s ease-in-out 1 forwards;
}

@keyframes foodItemWiggle {
  0%,
  100% {
    transform: translateX(0);
  }
  50% {
    transform: translateX(4rpx);
  }
}

.fullness-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 50px;
  border: 2rpx solid rgba(120, 70, 80, 0.5);
  border-radius: 14rpx;
  padding: 0 14rpx;
  font-weight: 700;
  background: #f8cd91;
  box-shadow: inset 0 2rpx 4rpx rgba(255, 255, 255, 0.35);
}

.fullness-btn text {
  font-size: 28rpx;
}

.n {
  font-size: 36rpx;
}

.milktea-block {
  margin-bottom: 10rpx;
}

.milktea-sugar-drawer {
  overflow: hidden;
  animation: milktea-open 0.28s ease-out;
  margin: -6rpx 0 0;
  padding: 0 8rpx 10rpx;
}

@keyframes milktea-open {
  from {
    opacity: 0;
    max-height: 0;
    transform: translateY(-8rpx);
  }
  to {
    opacity: 1;
    max-height: 200rpx;
    transform: translateY(0);
  }
}

.sugar-title {
  display: block;
  font-size: 24rpx;
  font-weight: 800;
  color: #5a3038;
  padding: 8rpx 6rpx 6rpx;
}

.sugar-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.sugar-chip {
  height: 50px;
  padding: 0 20rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.55);
  border: 2rpx solid rgba(120, 70, 80, 0.45);
  color: #4a2830;
}

.sugar-chip-on {
  background: linear-gradient(180deg, #ffd4dc 0%, #f5a8b8 100%);
  border-color: rgba(120, 70, 80, 0.75);
  animation: foodItemWiggle 0.8s ease-in-out 1 forwards;
}
