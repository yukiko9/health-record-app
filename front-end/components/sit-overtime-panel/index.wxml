<view class="metric-panel sit-overtime-panel">
  <view class="metric-card metric-card-active">
    <view class="metric-card-head">久坐时长</view>
    <view class="metric-card-body" catchtap="stopBubble">
      <input
        class="metric-input"
        type="digit"
        value="{{timeStr}}"
        bindinput="onTimeInput"
      />
      <text class="metric-unit">分</text>
    </view>
  </view>
</view>
