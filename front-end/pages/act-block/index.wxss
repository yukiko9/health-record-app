.screen.act-block {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

.act-block .mood-emoji.icon-emoji {
  font-size: 88rpx;
}

.act-block {
  background: transparent;
}

.top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.return-btn {
  min-width: 200rpx;
  text-align: center;
  padding: 8rpx 0;
}

.score-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.score {
  font-size: 90rpx;
}

.score-caption {
  font-size: 28rpx;
  color: rgba(27, 35, 22, 0.62);
  font-weight: 700;
}

.content {
  flex: 1;
  min-height: 0;
  margin-top: 20rpx;
  display: flex;
  gap: 16rpx;
}

.menu {
  width: 156rpx;
  max-height: 72vh;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.menu-btn.slow-walk-btn,
.menu-btn.fast-walk-btn,
.menu-btn.jog-btn,
.menu-btn.run-btn,
.menu-btn.sit-overtime-btn,
.menu-btn.ride-btn {
  height: 84px;
  font-size: 18px;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-btn {
  padding: 14rpx 6rpx;
  font-weight: 700;
  font-size: 24rpx;
  line-height: 1.3;
  text-align: center;
  background: rgba(217, 247, 175, 0.96) !important;
  border: 3rpx solid rgba(80, 90, 72, 0.55) !important;
  border-radius: 20rpx !important;
  box-shadow: 0 10rpx 8rpx rgba(0, 0, 0, 0.18);
  backdrop-filter: blur(2rpx);
}

/* 侧栏菜单选中：持续左右晃动 */
.menu-btn-selected {
  transform: translateY(4rpx);
  box-shadow: inset 0 6rpx 12rpx rgba(38, 62, 35, 0.22), 0 2rpx 4rpx rgba(255, 255, 255, 0.35);
  filter: brightness(0.97);
  animation: menuSideWiggle 0.48s ease-in-out infinite;
}

@keyframes menuSideWiggle {
  0%,
  100% {
    transform: translateY(4rpx) translateX(0);
  }
  50% {
    transform: translateY(4rpx) translateX(3rpx);
  }
}

.act-panel-title {
  display: block;
  text-align: center;
  font-size: 34rpx;
  font-weight: 800;
  color: #2e4a22;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

@keyframes act-panel-bump {
  0% {
    transform: translateY(0);
  }
  35% {
    transform: translateY(-14rpx);
  }
  65% {
    transform: translateY(4rpx);
  }
  100% {
    transform: translateY(0);
  }
}

.act-panel-bump {
  animation: act-panel-bump 0.42s cubic-bezier(0.34, 1.2, 0.64, 1) 1;
}

.act-data-input {
  flex: 1;
  min-width: 0;
  padding: 20rpx 16rpx;
  border-width: 3rpx;
  box-shadow: inset 0 2rpx 12rpx rgba(255, 255, 255, 0.45);
}

.act-data-input-lined {
  background-color: rgba(255, 255, 255, 0.88);
  background-image: repeating-linear-gradient(
    to bottom,
    rgba(72, 72, 72, 0.18) 0,
    rgba(72, 72, 72, 0.18) 1px,
    transparent 1px,
    transparent 50px
  );
  background-size: 100% 50px;
  background-origin: padding-box;
  background-repeat: repeat;
}

.panel-user-note {
  position: relative;
  z-index: 1;
  display: block;
  font-size: 18px;
  line-height: 2;
  min-height: 100px;
  margin-top: 20rpx;
  padding: 12px 8px 20px;
  color: #2e3238;
  font-weight: 600;
  white-space: pre-wrap;
}

.save-act-btn,
.reset-act-btn {
  min-height: 108rpx !important;
  padding-top: 22rpx !important;
  padding-bottom: 22rpx !important;
  line-height: 1.25 !important;
}

.bottom-btns {
  margin-top: auto;
  padding-top: 24rpx;
  padding-bottom: 8rpx;
  display: flex;
  gap: 16rpx;
}

.bottom-btns button {
  flex: 1;
}
