.screen.sleep-noon-block {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
  overflow: hidden;
  padding: 0;
  width: 100%;
}

.sleep-noon-block {
  background: #d8f4fc;
  color: #111;
}

.sleep-full-slide {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 68rpx 24rpx 24rpx 24rpx;
}

.sleep-slide-noon {
  background: linear-gradient(180deg, #b8ecff 0%, #d8f4fc 45%, #e8f8fc 100%);
}

.sleep-slide-enter {
  animation: sleepSlideEnter 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.sleep-slide-exit-up {
  animation: sleepSlideExitUp 0.42s ease-in forwards;
}

@keyframes sleepSlideEnter {
  0% {
    transform: translateY(88%);
    opacity: 0.9;
  }
  72% {
    transform: translateY(0);
    opacity: 1;
  }
  86% {
    transform: translateY(-16rpx);
  }
  100% {
    transform: translateY(0);
  }
}

@keyframes sleepSlideExitUp {
  to {
    transform: translateY(-105%);
    opacity: 0.65;
  }
}

.top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.return-btn {
  min-width: 200rpx;
  text-align: center;
  padding: 8rpx 0;
}

.score-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.score {
  font-size: 90rpx;
  font-weight: 700;
}

.score-caption {
  font-size: 28rpx;
  color: rgba(29, 46, 55, 0.62);
  font-weight: 700;
}

.sleep-main {
  flex: 1;
  min-height: 0;
  margin-top: 24rpx;
  display: flex;
  gap: 20rpx;
  align-items: stretch;
}

.sleep-mode-btn {
  width: 170rpx;
  height: 500rpx;
  padding: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  box-sizing: border-box;
  background: #d9f7af;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 16rpx rgba(46, 91, 59, 0.12);
  border: 5px solid rgba(50, 90, 70, 0.45);
}

.sleep-mode-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-height: 0;
  width: 100%;
}

.sleep-mode-title {
  text-align: center;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.25;
  color: #1e2a18;
  white-space: pre-line;
}

.sleep-mode-icon {
  flex-shrink: 0;
}

.sleep-mode-hint-slot {
  flex-shrink: 0;
  width: 100%;
  padding-top: 8rpx;
  padding-bottom: 4rpx;
  box-sizing: border-box;
}

.sleep-mode-switch-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.35;
  color: rgba(30, 55, 45, 0.9);
  white-space: pre-line;
  animation: sleepHintPulse 2.2s ease-in-out infinite;
}

@keyframes sleepHintPulse {
  0%,
  100% {
    opacity: 0.35;
  }
  50% {
    opacity: 1;
  }
}

.sleep-control {
  flex: 1;
  display: grid;
  grid-template-columns: minmax(88rpx, 1fr) auto minmax(88rpx, 1fr);
  grid-template-rows: auto auto;
  gap: 16rpx 12rpx;
  align-items: center;
}

.sleep-hour-reduce {
  grid-column: 1;
  grid-row: 1;
  justify-self: stretch;
  min-height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  background: #facd91;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 10rpx rgba(46, 91, 59, 0.1);
  padding-right: 24rpx;
  box-sizing: border-box;
}

.sleep-hour-add {
  grid-column: 3;
  grid-row: 1;
  justify-self: stretch;
  min-height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  background: #facd91;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 10rpx rgba(46, 91, 59, 0.1);
  padding-left: 24rpx;
  box-sizing: border-box;
}

.sleep-hour {
  grid-column: 2;
  grid-row: 1;
  justify-self: center;
  align-self: center;
  min-height: 140rpx;
  height: 140rpx;
  width: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 90rpx;
  font-weight: 700;
  background: #d9f7af;
  border-radius: 18rpx;
  box-shadow: inset 0 2rpx 6rpx rgba(255, 255, 255, 0.4);
}

.sleep-hour-bump {
  animation: sleepHourBump 0.38s cubic-bezier(0.34, 1.2, 0.64, 1);
}

@keyframes sleepHourBump {
  0%,
  100% {
    transform: scale(1);
  }
  40% {
    transform: scale(1.08) translateY(-6rpx);
  }
  70% {
    transform: scale(0.98) translateY(4rpx);
  }
}

.sleep-save-btn {
  grid-column: 1 / -1;
  grid-row: 2;
  min-width: 60vw;
  min-height: 120rpx;
  line-height: 1.2;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
  font-size: 50rpx;
}

.sleep-buddy-card {
  margin-top: auto;
  margin-left: -24rpx;
  margin-right: -24rpx;
  align-self: stretch;
  box-sizing: border-box;
  padding: 20rpx 18rpx 28rpx;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.sleep-buddy-float {
  animation: sleepBuddyFloat 2.8s ease-in-out infinite;
}

@keyframes sleepBuddyFloat {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

.sleep-buddy-img {
  display: block;
  width: 100%;
  height: auto;
  border-radius: 0;
}

.sleep-buddy-note {
  font-size: 26rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #e8f8fc;
  text-align: center;
  padding: 0 12rpx;
}

.sleep-noon-block .sleep-mode-btn .icon-emoji {
  font-size: 58rpx;
}

.sleep-noon-block .mood-emoji.icon-emoji {
  font-size: 82rpx;
}
