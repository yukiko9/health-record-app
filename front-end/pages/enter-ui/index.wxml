<view class="screen enter-ui">
  <view class="page-bg-layer page-bg-breathe-enter" style="{{pageBgStyle}}" />
  <view class="binder-decor-layer" aria-hidden="true" />
  <view class="bubble-layer">
    <view class="foam-bubble foam-a"></view>
    <view class="foam-bubble foam-b"></view>
    <view class="foam-bubble foam-c"></view>
    <view class="foam-bubble foam-d"></view>
    <view class="foam-bubble foam-e"></view>
    <view class="foam-bubble foam-f"></view>
    <view class="foam-bubble foam-g"></view>
    <view class="foam-bubble foam-h"></view>
    <view class="foam-bubble foam-i"></view>
    <view class="foam-bubble foam-j"></view>
    <view class="foam-bubble foam-k"></view>
    <view class="foam-bubble foam-l"></view>
    <view class="foam-bubble foam-m"></view>
    <view class="foam-bubble foam-n"></view>
    <view class="foam-bubble foam-o"></view>
    <view class="foam-bubble foam-p"></view>
    <view class="foam-bubble foam-q"></view>
    <view class="foam-bubble foam-r"></view>
  </view>
  <view class="enter-ui-foreground">
  <floating-bubbles />

  <view class="enter-main" bindtap="enterMainUi">
    <view class="goal-tip">
      <text>目标:</text>
      <text class="goal">{{goal}}</text>
      <text> </text>
      <text class="situation">{{situation}}</text>
    </view>

    <view class="mood-nudge-wrap">
      <text class="mood-emoji icon-emoji">{{moodEmoji}}</text>
    </view>
    <view class="score-bump-wrap {{scoreBump ? 'score-entry-bump' : ''}}">
      <view class="score-nudge-hint">
        <rolling-score score-class="score label-strong" value="{{score}}" />
      </view>
    </view>
    <view class="username-row">
      <view class="username label-strong">{{username}}</view>
      <view class="sync-nickname-btn card pressable" catchtap="syncWechatNickname" hover-class="pressing">同步微信昵称</view>
    </view>
    <view class="float-tip">点击空白处进入</view>
  </view>

  <view class="readme-fab-col" catchtap="noopReadme">
    <view class="readme-btn card pressable" catchtap="openReadme" hover-class="pressing">?</view>
    <text class="readme-fab-caption">用户说明</text>
  </view>

  <view wx:if="{{readmeVisible}}" class="readme-mask" catchtap="closeReadme">
    <view class="readme-page card" catchtap="noopReadme">
      <view class="readme-close pressable" catchtap="closeReadme" hover-class="pressing">×</view>
      <scroll-view scroll-y class="readme-scroll">
        <text class="readme-placeholder" selectable>
          （请在此处编写使用说明正文；也可替换为 rich-text 等组件。）
        </text>
      </scroll-view>
    </view>
  </view>
  </view>
</view>
